            "value": "Don't forget to track your time!"
          }
        }
      }
    },
    "idle.msg1": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Zeit vergeht — vergiss nicht, sie zu erfassen!"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Time flies when you're not tracking it!"
          }
        }
      }
    },
    "idle.msg2": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dein Timer vermisst dich."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your timer misses you."
          }
        }
      }
    },
    "idle.msg3": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Arbeitest du gerade an etwas? Starte die Zeiterfassung!"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Are you working on something? Start tracking!"
          }
        }
      }
    },
    "idle.msg4": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Eine unerfasste Minute ist gerade vergangen!"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "An untracked minute just passed!"
          }
        }
      }
    },
    "idle.msg5": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erfasste Zeit ist 100% besser abrechenbar."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tracked time is 100% more billable."
          }
        }
      }
    },
    "idle.msg6": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dein Stundenzettel fühlt sich leer an."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your timesheet feels empty."
          }
        }
      }
    },
    "idle.msg7": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Noch da? Lass uns den Timer starten!"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Still here? Let's get that timer going!"
          }
        }
      }
    },
    "idle.msg8": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Zeit verrinnt unerfasst."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Time is slipping away untracked."
          }
        }
      }
    },
    "idle.msg9": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Lass deine Arbeit nicht unbemerkt! Starte einen Timer."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Don't let your work go unnoticed! Start a timer."
          }
        }
      }
    },
    "idle.msg10": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Pro-Tipp: Jetzt erfassen ist besser als später erinnern."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pro tip: tracking now beats remembering later."
          }
        }
      }
    },
    "idle.msg11": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dein zukünftiges Ich wird dir für die Zeiterfassung danken."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your future self will thank you for tracking this."
          }
        }
      }
